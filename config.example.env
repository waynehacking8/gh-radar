# gh-radar configuration — copy to `config.env` and fill in.
#   cp config.example.env config.env  &&  $EDITOR config.env

# --- GitHub (optional but recommended) -------------------------------------
# Without a token the GitHub API allows 60 requests/hour, which a busy day can
# exhaust. A read-only classic token (no scopes needed) raises it to 5000/hr.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Email delivery (Gmail) -------------------------------------------------
# Use a Gmail *App Password*, NOT your normal password. Requires 2FA enabled.
# Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=
EMAIL_TO=you@gmail.com

# --- Tuning (optional) ------------------------------------------------------
MIN_STARS=30          # ignore repos with fewer total stars
SEEN_TTL_DAYS=90      # prevent old projects recycling into the alert
GH_RADAR_TARGET_ITEMS=5  # Tier B fills up to this normal digest size
GH_RADAR_SAFETY_CAP=10   # Tier A can expand beyond target, but never beyond this

# Importance gate (optional overrides; defaults shown). A repo is sent only if
# it clears one decisive threshold or is corroborated by independent sources.
GH_RADAR_TOP_TRENDING_RANK=3
GH_RADAR_MOMENTUM_STARS_PER_DAY=250
GH_RADAR_STRONG_HN_POINTS=100
GH_RADAR_STRONG_X_LIKES=100
GH_RADAR_STRONG_REDDIT_POINTS=300
GH_RADAR_STRONG_LOBSTERS_SCORE=50
GH_RADAR_BREAKOUT_NEW_REPO_STARS=1000

# Tier A / must-send single-source thresholds. Two independently active source
# families also make Tier A at the moderate thresholds built into config.py.
GH_RADAR_MUST_SEND_STARS_PER_DAY=500
GH_RADAR_MUST_SEND_HN_POINTS=200
GH_RADAR_MUST_SEND_X_LIKES=300
GH_RADAR_MUST_SEND_REDDIT_POINTS=750
GH_RADAR_MUST_SEND_LOBSTERS_SCORE=100
GH_RADAR_MUST_SEND_NEW_REPO_STARS=2000

GH_RADAR_SOURCE_MAX_AGE_HOURS=48
GH_RADAR_NEW_REPO_MAX_AGE_DAYS=7
GH_RADAR_TIMEZONE=Asia/Taipei

# --- Obsidian (optional) ----------------------------------------------------
# If set, also drops a copy of each digest as a Markdown note in this folder.
# GH_RADAR_VAULT=/home/richard/Wayne/雜記
