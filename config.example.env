# gh-radar configuration — copy to `config.env` and fill in.
#   cp config.example.env config.env  &&  $EDITOR config.env

# --- GitHub (optional but recommended) -------------------------------------
# Without a token the GitHub API allows 60 requests/hour, which a busy day can
# exhaust. A read-only classic token (no scopes needed) raises it to 5000/hr.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Email delivery (Gmail) -------------------------------------------------
# Use a Gmail *App Password*, NOT your normal password. Requires 2FA enabled.
# Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=waynehacking8@users.noreply.github.com
SMTP_PASS=
EMAIL_TO=waynehacking8@users.noreply.github.com

# --- Tuning (optional) ------------------------------------------------------
MIN_STARS=30          # ignore repos with fewer total stars
SEEN_TTL_DAYS=14      # don't re-show a repo seen within this many days

# --- Obsidian (optional) ----------------------------------------------------
# If set, also drops a copy of each digest as a Markdown note in this folder.
# GH_RADAR_VAULT=/home/richard/Wayne/雜記
